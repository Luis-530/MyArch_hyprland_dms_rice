[Desktop Entry]
Name=KchmViewer
Categories=Qt;KDE;Office;Viewer;
Terminal=false
Type=Application
Exec=env QT_IM_MODULE=fcitx QT_SCALE_FACTOR=1.5 kchmviewer %f
Icon=kchmviewer
GenericName=CHM file viewer
Comment=A viewer of CHM (MS-Help) files
MimeType=application/chm;application/x-chm;application/vnd.ms-htmlhelp;application/epub+zip
